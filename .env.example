# Binance API（公共数据不需要 key）
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_BASE_URL=https://api.binance.com

# Deribit API
DERIBIT_BASE_URL=https://www.deribit.com/api/v2

# Polymarket 实盘交易
PM_PRIVATE_KEY=               # Polygon 钱包私钥（API 凭证自动派生）
# PM_HOST=https://clob.polymarket.com   # 默认值已内置
# PM_FUNDER=                  # 可选, 用于代理签名

# py-clob-client 库路径（Polymarket 下单 SDK）
PY_CLOB_CLIENT_PATH=/path/to/py-clob-client

# 日志
LOG_DIR=logs
